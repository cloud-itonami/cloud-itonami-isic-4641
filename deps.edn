{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the kotoba-lang org of this workspace (transferred + renamed from
 ;; com-junkawasaki/langgraph-clj / com-junkawasaki/langchain-clj).
 ;;
 ;; Like the fuel-wholesale (`cloud-itonami-isic-4671`), general-trading,
 ;; commission-brokerage, agri-wholesale, provision-trading and metal-
 ;; wholesale siblings, this textile/apparel/footwear-wholesale vertical is
 ;; SELF-CONTAINED: there is no `kotoba-lang/textiletrade` to delegate
 ;; textile-trading validation to, so the credit-clearance / contract-on-
 ;; file / forced-labor-supply-chain / sanctions-screening checks live as
 ;; direct entity boolean reads in `textiletrade.governor` rather than
 ;; wrapping an external lib. This repo is standalone (forkable outside the
 ;; workspace); the :local/root paths only resolve inside the monorepo
 ;; checkout -- a standalone fork should override them with git
 ;; coordinates.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}
        ;; langchain-store: the shared langchain.db store seam (EDN-blob
        ;; codec + identity schema + event-log helpers) that ~190 actors
        ;; hand-roll; textiletrade.store is an adopter (ADR-2607141600).
        io.github.kotoba-lang/langchain-store
        {:local/root "../../kotoba-lang/langchain-store"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "textiletrade.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
